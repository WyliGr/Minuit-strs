---
interface Props {
  availableCinemas: string[];
  activeCinemas: Set<string>;
  filterVost: boolean;
  filterPast: boolean;
}

const { availableCinemas, activeCinemas, filterVost, filterPast } = Astro.props;
---

<div class="sticky top-0 z-50 bg-[#0a0a09]/90 backdrop-blur-xl py-4 border-b border-neutral-800/60 mb-6 space-y-4">
  <div class="flex flex-col gap-4">
    <div class="relative w-full">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      <input id="search-input" type="text" placeholder="Rechercher un film..."
             class="w-full bg-neutral-900 border border-neutral-800 text-neutral-200 rounded-md pl-9 pr-3 py-2.5 text-sm focus:ring-1 focus:ring-neutral-500 focus:border-neutral-500 outline-none transition-all placeholder-neutral-600">
    </div>

    <div class="flex gap-2 overflow-x-auto hide-scroll -mx-4 px-4">
      {availableCinemas.map(cinema => {
        const isActive = activeCinemas.has(cinema);
        return (
          <button data-cinema-target={cinema} class={`cinema-btn flex-shrink-0 px-3 py-1.5 rounded-md text-xs font-semibold transition-all border whitespace-nowrap ${isActive ? 'bg-white text-black border-white' : 'bg-transparent text-neutral-500 border-neutral-800'}`}>
            {cinema}
          </button>
        );
      })}
    </div>

    <div class="flex gap-2">
      <label class="flex-1 flex items-center justify-center gap-2 cursor-pointer text-xs font-medium text-neutral-400 bg-neutral-900/50 px-3 py-2.5 rounded-md border border-neutral-800 hover:text-neutral-200 hover:bg-neutral-800 transition-colors select-none">
        <input id="filter-vost" type="checkbox" class="hidden" {filterVost && 'checked'}/>
        <span id="label-vost">VOST</span>
        <div id="dot-vost" class={`w-2 h-2 rounded-full ${filterVost ? 'bg-white' : 'bg-neutral-700'}`} />
      </label>
      <label class="flex-1 flex items-center justify-center gap-2 cursor-pointer text-xs font-medium text-neutral-400 bg-neutral-900/50 px-3 py-2.5 rounded-md border border-neutral-800 hover:text-neutral-200 hover:bg-neutral-800 transition-colors select-none">
        <input id="filter-past" type="checkbox" class="hidden" {filterPast && 'checked'}/>
        <span id="label-past">Passé</span>
        <div id="dot-past" class={`w-2 h-2 rounded-full ${filterPast ? 'bg-white' : 'bg-neutral-700'}`} />
      </label>
    </div>
  </div>
</div>

<div id="empty-state" class="hidden text-center py-24">
  <p class="text-neutral-500 font-medium">Aucune séance ne correspond à vos filtres.</p>
  <button id="reset-btn" class="mt-4 text-sm text-neutral-400 underline hover:text-white transition-colors">Réinitialiser</button>
</div>

<style>
  .hide-scroll::-webkit-scrollbar { display: none; }
  .hide-scroll { -ms-overflow-style: none; scrollbar-width: none; }
</style>