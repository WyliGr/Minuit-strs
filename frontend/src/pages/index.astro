---
import { fetchMovies, formatDuration } from '../services/api';
import MovieList from '../components/MovieList.astro';
import Filters from '../components/Filters.astro';

import '../styles/global.css'

let movies = [];
let errorMessage = "";

try {
  movies = await fetchMovies();
} catch (error) {
  console.error("🚨 ERREUR LORS DU FETCH N8N :", error);
  errorMessage = error instanceof Error ? error.message : "Erreur inconnue";
}

const availableCinemas = ['UGC', 'Vox', 'Le Cosmos', 'Star', 'Star SE'];
---

<html lang="fr" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minuit.strs</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        
        body { font-family: 'Inter', system-ui, sans-serif; }
        .hide-scroll::-webkit-scrollbar { display: none; }
        .hide-scroll { -ms-overflow-style: none; scrollbar-width: none; }
        
        .seance-badge.is-past {
            background-color: transparent !important;
            border-color: #171717 !important;
            color: #404040 !important;
            pointer-events: none;
        }
        .seance-badge.is-past .time-text {
            text-decoration: line-through;
        }
        .seance-badge.is-past .vost-tag {
            display: none !important;
        }
    </style>
</head>
<body class="bg-[#0a0a0a] text-neutral-300 min-h-screen selection:bg-neutral-800 selection:text-white antialiased">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 pb-32">
        
        <header class="mb-10 border-b border-neutral-800/60 pb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-white">
                    Minuit.strs
                </h1>
                <p class="text-neutral-500 text-sm mt-2 font-medium">Séances du jour générées par @WyliGr</p>
            </div>
            <div id="clock" class="text-sm font-mono text-neutral-600 bg-neutral-900/50 px-3 py-1.5 rounded-md border border-neutral-800">
                --:--
            </div>
        </header>

        {errorMessage && (
            <div class="mb-8 p-4 bg-red-900/30 border border-red-800 rounded-md text-red-400 text-sm">
                Une erreur est survenue lors de la récupération des séances : {errorMessage}
            </div>
        )}

        <Filters 
          availableCinemas={availableCinemas} 
          activeCinemas={new Set(availableCinemas)} 
          filterVost={false} 
          filterPast={false} 
          client:load />

        <MovieList 
          movies={movies} 
          activeCinemas={new Set(availableCinemas)} 
          currentMinutes={0} 
          filterVost={false} 
          filterPast={false} 
          client:load />
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
            const filterVost = document.getElementById('filter-vost') as HTMLInputElement | null;
            const filterPast = document.getElementById('filter-past') as HTMLInputElement | null;
            const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement | null;
            const clockEl = document.getElementById('clock') as HTMLElement | null;
            const cinemaBtns = document.querySelectorAll<HTMLButtonElement>('.cinema-btn');
            const emptyState = document.getElementById('empty-state') as HTMLElement | null;
            
            if (!searchInput || !filterVost || !filterPast || !resetBtn || !clockEl || !emptyState) return;

            let activeCinemas = new Set(Array.from(cinemaBtns).map(btn => btn.dataset.cinemaTarget!));
            let currentMinutes = 0;

            const updateClock = () => {
                const now = new Date();
                const h = now.getHours();
                const m = now.getMinutes();
                clockEl.textContent = `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
                currentMinutes = h * 60 + m;
                applyFilters();
            };

            const applyFilters = () => {
                const searchVal = searchInput.value.toLowerCase();
                const onlyVost = filterVost.checked;
                const hidePast = filterPast.checked;
                let visibleMovies = 0;

                document.getElementById('label-vost')?.classList.toggle('text-white', onlyVost);
                document.getElementById('dot-vost')?.classList.toggle('bg-white', onlyVost);
                document.getElementById('dot-vost')?.classList.toggle('bg-neutral-700', !onlyVost);
                
                document.getElementById('label-past')?.classList.toggle('text-white', hidePast);
                document.getElementById('dot-past')?.classList.toggle('bg-white', hidePast);
                document.getElementById('dot-past')?.classList.toggle('bg-neutral-700', !hidePast);

                document.querySelectorAll<HTMLElement>('.movie-article').forEach(movie => {
                    const title = movie.dataset.title || '';
                    const matchesSearch = title.includes(searchVal);
                    let hasVisibleSeance = false;

                    movie.querySelectorAll<HTMLElement>('.cinema-group').forEach(group => {
                        const cinemaName = group.dataset.cinema || '';
                        const isCinemaActive = activeCinemas.has(cinemaName);
                        let groupHasVisibleSeance = false;

                        group.querySelectorAll<HTMLElement>('.seance-badge').forEach(badge => {
                            const timeStr = badge.dataset.time || '00:00';
                            const [h, m] = timeStr.split(':').map(Number);
                            const isPast = (h * 60 + m) < currentMinutes;
                            const isVost = badge.dataset.vost === "true";

                            if (isPast) {
                                badge.classList.add('is-past');
                            } else {
                                badge.classList.remove('is-past');
                            }

                            let showBadge = true;
                            if (onlyVost && !isVost) showBadge = false;
                            if (hidePast && isPast) showBadge = false;

                            if (showBadge && isCinemaActive) {
                                badge.style.display = 'inline-flex';
                                groupHasVisibleSeance = true;
                            } else {
                                badge.style.display = 'none';
                            }
                        });

                        if (groupHasVisibleSeance) {
                            group.style.display = 'flex';
                            hasVisibleSeance = true;
                        } else {
                            group.style.display = 'none';
                        }
                    });

                    if (matchesSearch && hasVisibleSeance) {
                        movie.style.display = 'flex';
                        visibleMovies++;
                    } else {
                        movie.style.display = 'none';
                    }
                });

                emptyState.style.display = visibleMovies === 0 ? 'block' : 'none';
            };

            searchInput.addEventListener('input', applyFilters);
            filterVost.addEventListener('change', applyFilters);
            filterPast.addEventListener('change', applyFilters);
            
            cinemaBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const currentTarget = e.currentTarget as HTMLButtonElement;
                    const target = currentTarget.dataset.cinemaTarget!;
                    
                    if (activeCinemas.has(target)) {
                        activeCinemas.delete(target);
                        currentTarget.classList.replace('bg-white', 'bg-transparent');
                        currentTarget.classList.replace('text-black', 'text-neutral-500');
                        currentTarget.classList.replace('border-white', 'border-neutral-800');
                    } else {
                        activeCinemas.add(target);
                        currentTarget.classList.replace('bg-transparent', 'bg-white');
                        currentTarget.classList.replace('text-neutral-500', 'text-black');
                        currentTarget.classList.replace('border-neutral-800', 'border-white');
                    }

                    if (activeCinemas.size === 0) {
                        cinemaBtns.forEach(b => {
                            activeCinemas.add(b.dataset.cinemaTarget!);
                            b.classList.replace('bg-transparent', 'bg-white');
                            b.classList.replace('text-neutral-500', 'text-black');
                            b.classList.replace('border-neutral-800', 'border-white');
                        });
                    }
                    
                    applyFilters();
                });
            });

            resetBtn.addEventListener('click', () => {
                searchInput.value = '';
                filterVost.checked = false;
                filterPast.checked = false;
                cinemaBtns.forEach(b => {
                    activeCinemas.add(b.dataset.cinemaTarget!);
                    b.classList.replace('bg-transparent', 'bg-white');
                    b.classList.replace('text-neutral-500', 'text-black');
                    b.classList.replace('border-neutral-800', 'border-white');
                });
                applyFilters();
            });

            updateClock();
            setInterval(updateClock, 60000);
        });
    </script>
</body>
</html>