<!--
  Ce fichier contient la vue mobile du dashboard.
  Il est simplifié pour une meilleure expérience sur mobile.
-->
---
import { fetchMovies, formatDuration } from '../services/api';
import MovieListMobile from '../components/MovieListMobile.astro';
import FiltersMobile from '../components/FiltersMobile.astro';

import '../styles/global.css'

let movies: Array<{
  titre: string;
  duree: string | number;
  affiche?: string;
  seances: Record<string, Array<{
    time: string;
    isVost: boolean;
  }>>;
}> = [];
let errorMessage = "";

try {
  movies = await fetchMovies();
} catch (error) {
  console.error("🚨 ERREUR LORS DU FETCH N8N :", error);
  errorMessage = error instanceof Error ? error.message : "Erreur inconnue";
}

const availableCinemas = ['UGC', 'Vox', 'Le Cosmos', 'Star', 'Star SE'];
---

<html lang="fr" class="dark">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Programmes de cinéma à Strasbourg - Minuit.strs</title>
        <meta name="description" content="Consultez tous les programmes de cinéma de Strasbourg en temps réel. Vox, UGC, Cosmos, Star et Star Saint-Exupéry en un seul endroit.">
        <meta name="keywords" content="cinéma, Strasbourg, programmes, films, Vox, UGC, Cosmos, Star, Star Saint-Exupéry, horaires, séances">
        <meta name="author" content="WyliGr">
        <meta property="og:title" content="Programmes de cinéma à Strasbourg - Minuit.strs">
        <meta property="og:description" content="Consultez tous les programmes de cinéma de Strasbourg en temps réel. Vox, UGC, Cosmos, Star et Star Saint-Exupéry en un seul endroit.">
        <meta property="og:type" content="website">
        <meta property="og:url" content="https://cinema.wyliam.fr/dashboard">
        <meta property="og:image" content="https://cinema.wyliam.fr/favicon.ico">
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="Programmes de cinéma à Strasbourg - Minuit.strs">
        <meta name="twitter:description" content="Consultez tous les programmes de cinéma de Strasbourg en temps réel. Vox, UGC, Cosmos, Star et Star Saint-Exupéry en un seul endroit.">
        <meta name="twitter:image" content="https://cinema.wyliam.fr/favicon.ico">
        <link rel="canonical" href="https://cinema.wyliam.fr/dashboard">
        <meta name="robots" content="index, follow">
        <meta name="googlebot" content="index, follow">
        <meta name="theme-color" content="#0a0a09">
        <link rel="icon" type="image/x-icon" href="/favicon.ico">
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body { font-family: 'Inter', system-ui, sans-serif; }
        .hide-scroll::-webkit-scrollbar { display: none; }
        .hide-scroll { -ms-overflow-style: none; scrollbar-width: none; }

        .seance-badge.is-past {
            background-color: transparent !important;
            border-color: #171717 !important;
            color: #404040 !important;
            pointer-events: none;
        }
        .seance-badge.is-past .time-text {
            text-decoration: line-through;
        }
        .seance-badge.is-past .vost-tag {
            display: none !important;
        }
    </style>
</head>
 <body class="bg-[#0a0a09] text-neutral-300 min-h-screen selection:bg-neutral-800 selection:text-white antialiased">
     <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 pb-24">
        <header class="mb-6 border-b border-neutral-800/60 pb-6">
            <div class="flex justify-between items-center gap-4">
                <div>
                    <h1 class="text-2xl font-bold tracking-tight text-white"><a href="/">Minuit.strs</a></h1>
                    <p class="text-neutral-500 text-xs mt-1 font-medium">Séances du jour</p>
                </div>
                <div id="clock" class="text-sm font-mono text-neutral-600 bg-neutral-900/50 px-3 py-1.5 rounded-md border border-neutral-800">
                    --:--
                </div>
            </div>
        </header>
 
        {errorMessage && (
            <div class="mb-6 p-4 bg-red-900/30 border border-red-800 rounded-md text-red-400 text-sm">
                Une erreur est survenue : {errorMessage}
            </div>
        )}
 
        <FiltersMobile 
          availableCinemas={availableCinemas} 
          activeCinemas={new Set(availableCinemas)} 
          filterVost={false} 
          filterPast={false} 
          client:load />
 
        <MovieListMobile 
          movies={movies} 
          activeCinemas={new Set(availableCinemas)} 
          currentMinutes={0} 
          filterVost={false} 
          filterPast={false} 
          client:load />
    </div>
 
    <footer class="mt-16 py-8 border-t border-neutral-800/60 text-center text-neutral-500 text-xs">
        <div class="flex justify-center items-center gap-4 flex-wrap">
            <span>© 2026 Minuit.strs</span>
            <a href="https://github.com/WyliGr/Minuit-strs" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                <span>GitHub</span>
            </a>
        </div>
        <div class="mt-2">
            <span>Made with 🖤 by Wyligr</span>
        </div>
    </footer>
     
    <div id="poster-modal" class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <button id="close-modal" class="absolute top-4 right-4 text-white text-2xl z-10">×</button>
        <img id="modal-image" src="" alt="Affiche en grand format" class="max-h-[90vh] max-w-full rounded-lg shadow-2xl">
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
            const filterVost = document.getElementById('filter-vost') as HTMLInputElement | null;
            const filterPast = document.getElementById('filter-past') as HTMLInputElement | null;
            const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement | null;
            const clockEl = document.getElementById('clock') as HTMLElement | null;
            const cinemaBtns = document.querySelectorAll<HTMLButtonElement>('.cinema-btn');
            const emptyState = document.getElementById('empty-state') as HTMLElement | null;
            const modal = document.getElementById('poster-modal') as HTMLElement | null;
            const modalImage = document.getElementById('modal-image') as HTMLImageElement | null;
            const closeModal = document.getElementById('close-modal') as HTMLElement | null;
              
            if (!searchInput || !filterVost || !filterPast || !resetBtn || !clockEl || !emptyState || !modal || !modalImage || !closeModal) return;
  
            let activeCinemas = new Set(Array.from(cinemaBtns).map(btn => btn.dataset.cinemaTarget!));
            let currentMinutes = 0;
  
            const updateClock = () => {
                const now = new Date();
                const h = now.getHours();
                const m = now.getMinutes();
                clockEl.textContent = `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
                currentMinutes = h * 60 + m;
                applyFilters();
            };
  
            const applyFilters = () => {
                const searchVal = searchInput.value.toLowerCase();
                const onlyVost = filterVost.checked;
                const hidePast = filterPast.checked;
                let visibleMovies = 0;
  
                document.getElementById('label-vost')?.classList.toggle('text-white', onlyVost);
                document.getElementById('dot-vost')?.classList.toggle('bg-white', onlyVost);
                document.getElementById('dot-vost')?.classList.toggle('bg-neutral-700', !onlyVost);
                  
                document.getElementById('label-past')?.classList.toggle('text-white', hidePast);
                document.getElementById('dot-past')?.classList.toggle('bg-white', hidePast);
                document.getElementById('dot-past')?.classList.toggle('bg-neutral-700', !hidePast);
  
                document.querySelectorAll<HTMLElement>('.movie-article').forEach(movie => {
                    const title = movie.dataset.title || '';
                    const matchesSearch = title.includes(searchVal);
                    let hasVisibleSeance = false;
  
                    movie.querySelectorAll<HTMLElement>('.cinema-group').forEach(group => {
                        const cinemaName = group.dataset.cinema || '';
                        const isCinemaActive = activeCinemas.has(cinemaName);
                        let groupHasVisibleSeance = false;
  
                        group.querySelectorAll<HTMLElement>('.seance-badge').forEach(badge => {
                            const timeStr = badge.dataset.time || '00:00';
                            const [h, m] = timeStr.split(':').map(Number);
                            const isPast = (h * 60 + m) < currentMinutes;
                            const isVost = badge.dataset.vost === "true";
  
                            if (isPast) {
                                badge.classList.add('is-past');
                            } else {
                                badge.classList.remove('is-past');
                            }
  
                            let showBadge = true;
                            if (onlyVost && !isVost) showBadge = false;
                            if (hidePast && isPast) showBadge = false;
  
                            if (showBadge && isCinemaActive) {
                                badge.style.display = 'inline-flex';
                                groupHasVisibleSeance = true;
                            } else {
                                badge.style.display = 'none';
                            }
                        });
  
                        if (groupHasVisibleSeance) {
                            group.style.display = 'flex';
                            hasVisibleSeance = true;
                        } else {
                            group.style.display = 'none';
                        }
                    });
  
                    if (matchesSearch && hasVisibleSeance) {
                        movie.style.display = 'flex';
                        visibleMovies++;
                    } else {
                        movie.style.display = 'none';
                    }
                });
  
                emptyState.style.display = visibleMovies === 0 ? 'block' : 'none';
            };
  
            searchInput.addEventListener('input', applyFilters);
            filterVost.addEventListener('change', applyFilters);
            filterPast.addEventListener('change', applyFilters);
              
            cinemaBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const currentTarget = e.currentTarget as HTMLButtonElement;
                    const target = currentTarget.dataset.cinemaTarget!;
                      
                    if (activeCinemas.has(target)) {
                        activeCinemas.delete(target);
                        currentTarget.classList.replace('bg-white', 'bg-transparent');
                        currentTarget.classList.replace('text-black', 'text-neutral-500');
                        currentTarget.classList.replace('border-white', 'border-neutral-800');
                    } else {
                        activeCinemas.add(target);
                        currentTarget.classList.replace('bg-transparent', 'bg-white');
                        currentTarget.classList.replace('text-neutral-500', 'text-black');
                        currentTarget.classList.replace('border-neutral-800', 'border-white');
                    }
  
                    if (activeCinemas.size === 0) {
                        cinemaBtns.forEach(b => {
                            activeCinemas.add(b.dataset.cinemaTarget!);
                            b.classList.replace('bg-transparent', 'bg-white');
                            b.classList.replace('text-neutral-500', 'text-black');
                            b.classList.replace('border-neutral-800', 'border-white');
                        });
                    }
                      
                    applyFilters();
                });
            });
  
            resetBtn.addEventListener('click', () => {
                searchInput.value = '';
                filterVost.checked = false;
                filterPast.checked = false;
                cinemaBtns.forEach(b => {
                    activeCinemas.add(b.dataset.cinemaTarget!);
                    b.classList.replace('bg-transparent', 'bg-white');
                    b.classList.replace('text-neutral-500', 'text-black');
                    b.classList.replace('border-neutral-800', 'border-white');
                });
                applyFilters();
            });
  
            document.querySelectorAll('.poster-image').forEach(img => {
                img.addEventListener('click', () => {
                    const posterUrl = img.getAttribute('data-poster');
                    if (posterUrl) {
                        modalImage.src = posterUrl;
                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                    }
                });
            });
  
            closeModal.addEventListener('click', () => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            });
  
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {
                    e.preventDefault();
                    const movies = document.querySelectorAll('.movie-article');
                    const currentFocus = document.activeElement;
                    let currentIndex = -1;

                    movies.forEach((movie, index) => {
                        if (movie === currentFocus || movie.contains(currentFocus)) {
                            currentIndex = index;
                        }
                    });

                    if (e.key === 'ArrowDown' && currentIndex < movies.length - 1) {
                        movies[currentIndex + 1].querySelector('h2')?.focus();
                    } else if (e.key === 'ArrowUp' && currentIndex > 0) {
                        movies[currentIndex - 1].querySelector('h2')?.focus();
                    }
                }
            });

            updateClock();
            setInterval(updateClock, 60000);
        });
    </script>
</body>
</html>